# 환경변수 키 템플릿 (값 없음, 공개) — ARCHITECTURE.md 7절
# 실제 값은 .env.local 에 넣고 절대 커밋하지 않는다.
# Phase 1(로컬 seed/store)은 아래 키 없이도 동작한다. Phase 2(Supabase) 진입 시 채운다.

# Supabase (Phase 2+)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# 사이트 절대 URL (OG·공유 링크·redirect 폴백)
NEXT_PUBLIC_SITE_URL=

# MyRealTrip 마케팅 파트너 REST API (서버 전용, 클라이언트 노출 금지)
MYREALTRIP_API_KEY=

# Host-create MCP PAT 인증 (원격/저장형 MCP 운영 시 필수)
# 단일 토큰 데모용. 실제 운영은 HOST_CREATE_MCP_PAT_TOKENS에 sha256:<hash> 키 사용 권장.
HOST_CREATE_MCP_BEARER_TOKEN=
HOST_CREATE_MCP_USER_ID=
HOST_CREATE_MCP_HOST_ID=
HOST_CREATE_MCP_SCOPES=read,write,publish
# JSON 예: {"sha256:<token_sha256>":{"user_id":"<supabase_user_id>","host_id":"<host_id>","scopes":["read","write"]}}
HOST_CREATE_MCP_PAT_TOKENS=
# MCP가 Next 앱의 .data/drafts.json을 임시 브릿지 store로 볼 루트
OURREALTRIP_APP_ROOT=/Users/vivi/ourrealtrip
